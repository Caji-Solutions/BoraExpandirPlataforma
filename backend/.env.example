# ============================================
# BoraExpandir Backend — Template de ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o .env com secrets.

# --- Servidor ---
NODE_ENV=production
PORT=4000

# URL pública onde o backend vai rodar (usada para webhooks, links em e-mails, etc.)
BACKEND_URL=https://ebe-api.boraexpandir.com.br

# URL pública do frontend (usada em redirecionamentos e e-mails)
FRONTEND_URL=https://bei.boraexpandir.com.br

# Lista separada por vírgula das origens permitidas (CORS)
CORS_ORIGINS=https://bei.boraexpandir.com.br,http://localhost:3010

# --- Supabase ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE=eyJhbGciOi...   # service_role key (NUNCA exponha no frontend)

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Composio / OpenAI Agents ---
COMPOSIO_API_KEY=
COMPOSIO_AUTH_CONFIG=

# --- SMTP (e-mail transacional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Autentique (assinatura digital) ---
AUTENTIQUE_WEBHOOK_SECRETS=
AUTENTIQUE_TOKEN=
AUTENTIQUE_COMPANY_EMAIL=

# --- MercadoPago (se aplicável) ---
MERCADOPAGO_ACCESS_TOKEN=
