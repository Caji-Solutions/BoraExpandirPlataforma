{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/modules/*": ["src/modules/*"],
      "@/components/*": ["src/modules/shared/components/*"],
      "@/hooks/*": ["src/modules/shared/hooks/*"],
      "@/services/*": ["src/modules/shared/services/*"],
      "@/utils/*": ["src/utils/*"],
      "@/types/*": ["src/modules/shared/types/*"],
      "@/contexts/*": ["src/contexts/*"],
      "@/lib/*": ["src/lib/*"]
    },
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
